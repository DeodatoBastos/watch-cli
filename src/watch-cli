#!/usr/bin/env bash

# --- Init: resolve script location and load config ---
SCRIPT_DIR="$(dirname "$(realpath "$0")")"
export CLIENT_PATH="${SCRIPT_DIR}/fetch_metadata.py"

ENV_FILE="${SCRIPT_DIR}/.env"
if [ -f "$ENV_FILE" ]; then
    set -a
    . "$ENV_FILE"
    set +a
fi

# fzf overrides TERM in preview subshells, so export Kitty detection early
if [ "$TERM" = "xterm-kitty" ]; then
    export IS_KITTY="true"
else
    export IS_KITTY="false"
fi

# Single source of truth for supported video extensions (consumed by all scripts)
export VIDEO_EXTS="mp4|mkv|avi|mov|flv|webm"

# --- Parse arguments ---
SEARCH_DIRS=("$HOME/Media/movies")

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        --dir)
            [[ -n "$2" ]] || { echo "Error: --dir requires a directory path."; exit 1; }
            SEARCH_DIRS=("$(realpath "$2")")
            shift 2
            ;;
        *) shift ;;
    esac
done

# --- Config paths (all helpers installed here by Makefile) ---
CONFIG_DIR="${HOME}/.config/watch-cli"
export WATCHED_FILE="${CONFIG_DIR}/watched.txt"
LUA_SCRIPT="${CONFIG_DIR}/mark_watched.lua"
export MARKER_SCRIPT="${CONFIG_DIR}/marker.py"
TOGGLE_SCRIPT="${CONFIG_DIR}/toggle_watched.py"
PREVIEW_MAIN="${CONFIG_DIR}/preview.sh"
PREVIEW_SEASON="${CONFIG_DIR}/preview_season.sh"
PREVIEW_EPISODE="${CONFIG_DIR}/preview_episode.sh"

mkdir -p "$CONFIG_DIR"
touch "$WATCHED_FILE"

# --- Playback ---

play_video() {
    local FULL_PATH="$1"
    local VIDEO_NAME
    VIDEO_NAME=$(basename "$FULL_PATH")
    clear

    local DISPLAY_MODE
    DISPLAY_MODE=$(printf "1. Terminal Mode (Kitty)\n2. GUI Mode (Full Screen)\n3. < Go Back" | fzf \
        --height=40% --layout=reverse --border \
        --prompt="Watch '$VIDEO_NAME' via > " \
        --header="[Enter] Choose | [q] Cancel")

    case "$DISPLAY_MODE" in
        *"Terminal"*)
            clear
            echo "Launching '$VIDEO_NAME' in terminal (Kitty)..."
            mpv --script="$LUA_SCRIPT" --save-position-on-quit \
                --profile=sw-fast --vo=kitty --vo-kitty-use-shm=yes \
                --really-quiet "$FULL_PATH" 2>/dev/null
            ;;
        *"GUI"*)
            clear
            echo "Launching '$VIDEO_NAME' in full-screen GUI..."
            mpv --script="$LUA_SCRIPT" --save-position-on-quit \
                --fs "$FULL_PATH" > /dev/null 2>&1
            ;;
        *) return 1 ;;
    esac
}

# --- Series / Season / Episode navigation ---

select_season() {
    local SERIES_DIR="$1"
    local RELOAD_CMD="find '$SERIES_DIR' -maxdepth 1 -mindepth 1 -type d | sort | python3 $MARKER_SCRIPT $WATCHED_FILE"

    eval "$RELOAD_CMD" | fzf \
        --height=80% --layout=reverse --border \
        --prompt="Select Season > " \
        --header="[Enter] Select | [q / Esc] Back | [w] Toggle Watched" \
        --delimiter=$'\t' --with-nth=2 \
        --bind="w:execute-silent(python3 $TOGGLE_SCRIPT $WATCHED_FILE {1})+reload($RELOAD_CMD)" \
        --preview-window=right:50%,wrap \
        --preview="bash $PREVIEW_SEASON {1}" | cut -f1
}

select_episode() {
    local SEASON_DIR="$1"
    local RELOAD_CMD="find '$SEASON_DIR' -type f 2>/dev/null | grep -iE '\.(${VIDEO_EXTS})$' | sort | python3 $MARKER_SCRIPT $WATCHED_FILE"

    eval "$RELOAD_CMD" | fzf \
        --height=80% --layout=reverse --border \
        --prompt="Select Episode > " \
        --header="[Enter] Select | [q / Esc] Back | [w] Toggle Watched" \
        --delimiter=$'\t' --with-nth=2 \
        --bind="w:execute-silent(python3 $TOGGLE_SCRIPT $WATCHED_FILE {1})+reload($RELOAD_CMD)" \
        --preview-window=right:50%,wrap \
        --preview="bash $PREVIEW_EPISODE {1}" | cut -f1
}

navigate_series() {
    local SELECTION="$1"
    local SEASONS_COUNT
    SEASONS_COUNT=$(find "$SELECTION" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | grep -c .)
    local SEASON_PATH=""

    while true; do
        # Pick season if there are subdirectories and none is selected yet
        if [ "$SEASONS_COUNT" -gt 0 ] && [ -z "$SEASON_PATH" ]; then
            SEASON_PATH=$(select_season "$SELECTION")
            [ -z "$SEASON_PATH" ] && return
        elif [ "$SEASONS_COUNT" -eq 0 ]; then
            SEASON_PATH="$SELECTION"
        fi

        local FULL_PATH
        FULL_PATH=$(select_episode "$SEASON_PATH")

        if [ -z "$FULL_PATH" ]; then
            # Go back to season selection if applicable, else exit series
            [ "$SEASONS_COUNT" -gt 0 ] && { SEASON_PATH=""; continue; }
            return
        fi

        play_video "$FULL_PATH"
    done
}

# --- Main selection loop ---

while true; do
    clear

    # Build the pipeline: find entries → add watched labels → fzf
    MAIN_FIND="find $(printf '%q ' "${SEARCH_DIRS[@]}") -maxdepth 1 -mindepth 1 -type d -o -type f 2>/dev/null | grep -iE '(/[^.][^/]*$|\.(${VIDEO_EXTS})$)'"
    MAIN_RELOAD="{ find $(printf '%q ' "${SEARCH_DIRS[@]}") -maxdepth 1 -mindepth 1 -type d 2>/dev/null; find $(printf '%q ' "${SEARCH_DIRS[@]}") -maxdepth 1 -mindepth 1 -type f 2>/dev/null | grep -iE '\.(${VIDEO_EXTS})$'; } | python3 $MARKER_SCRIPT $WATCHED_FILE"

    SELECTION=$(eval "$MAIN_RELOAD" | \
        fzf \
        --height=80% --layout=reverse --border \
        --prompt="Select Movie or Series > " \
        --header="[Enter] Select | [q / Esc] Quit | [w] Toggle Watched" \
        --delimiter=$'\t' --with-nth=2 \
        --bind="q:abort" \
        --bind="w:execute-silent(python3 $TOGGLE_SCRIPT $WATCHED_FILE {1})+reload($MAIN_RELOAD)" \
        --preview-window=right:50% \
        --preview="bash $PREVIEW_MAIN {1}")

    # Clear Kitty graphics on exit from main menu
    printf "\x1b_Ga=d,d=A\x1b\\"

    # Extract clean path (first tab-delimited field)
    SELECTION=$(echo "$SELECTION" | cut -f1)
    [ -z "$SELECTION" ] && { clear; echo "Exiting video selector. Goodbye!"; break; }

    if [ -d "$SELECTION" ]; then
        VIDEO_COUNT=$(find "$SELECTION" -type f 2>/dev/null | grep -icE "\.(${VIDEO_EXTS})$")

        if [ "$VIDEO_COUNT" -gt 1 ]; then
            navigate_series "$SELECTION"
            continue
        fi
        # Single-video folder (movie in a directory)
        FULL_PATH=$(find "$SELECTION" -type f 2>/dev/null | grep -iE "\.(${VIDEO_EXTS})$" | head -n 1)
    else
        FULL_PATH="$SELECTION"
    fi

    [ -n "$FULL_PATH" ] && play_video "$FULL_PATH"
done
